# --- App ---
NODE_ENV=development
PORT=3000
APP_NAME=Supplier Risk Analyzer API

# Comma-separated. Ex.: http://localhost:5173
# Deixe vazio em dev com proxy Vite; use em prod se front estiver noutro origin.
# CORS_ORIGIN=http://localhost:5173

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=supplier_risk_analyzer

# --- Auth ---
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# --- Uploads (relativo ao cwd do processo) ---
UPLOAD_DIR=storage/uploads
MAX_FILE_SIZE_BYTES=5242880

# --- Risk analyzer: keyword | llm | llm_with_fallback ---
RISK_ANALYZER_MODE=keyword

# --- LLM (necessário se RISK_ANALYZER_MODE=llm ou llm_with_fallback) ---
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_INPUT_CHARS=12000
# LLM_TIMEOUT_MS=60000
# LLM_JSON_OBJECT_MODE=true

# --- OCR (imagens) ---
# OCR_LANGS=por+eng
